# ── Twitch IRC (requerido) ────────────────────────────────────────────────────
TWITCH_BOT_USERNAME=nombre_del_bot
TWITCH_OAUTH_TOKEN=oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITCH_CHANNEL=nombre_del_canal

# ── Twitch EventSub — Channel Points y Follows (opcional) ────────────────────
# Obtener con: go run ./cmd/gettoken/
# Scopes requeridos: channel:read:redemptions moderator:read:followers
TWITCH_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITCH_BROADCASTER_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Spotify (opcional, para !song) ───────────────────────────────────────────
SPOTIFY_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SPOTIFY_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SPOTIFY_REFRESH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Wordle (opcional, para !wordle) ──────────────────────────────────────────
WORDLE_WORD=EJEMPLO

# ── Nintendo 3DS (opcional, para !3ds) ───────────────────────────────────────
DS3_IP=192.168.1.100
DS3_PORT=8888

# ── Overlay (opcional) ───────────────────────────────────────────────────────
OVERLAY_PORT=7373
